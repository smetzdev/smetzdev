---
import { twMerge } from "tailwind-merge";
const { class: className, href } = Astro.props;
const styles = twMerge(
  "bg-brawn-yellow pixel-dots-light text-brawn-gray text-center px-4 py-2 inline-block",
  "hover:bg-brawn-red hover:text-brawn-white font-pixel font-bold uppercase",
  className,
);
---

<a class={styles} target="_blank" href={href}>
  <slot />
</a>
